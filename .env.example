# Copy this file to .env and fill in your values
# Only the provider you use needs to be configured

# ---- Provider Selection ----
# Options: claude | openai | local
LLM_PROVIDER=claude

# ---- Claude (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# ---- Local vLLM ----
VLLM_URL=http://localhost:8000/v1
VLLM_MODEL=mistral-7b-instruct
